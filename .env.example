# =========================
# Agent V7.2 - Full .env Template
# NIM (GLM) > Gemini > Gemma rescue chain
# =========================

# ===== Required for main model =====
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.mimo.ai/v1
MIMO_MODEL=mimo-v2.5-pro

# ===== Rescue chain priority #1: GLM-4.7 via NVIDIA NIM =====
NIM_API_KEY=your_nvidia_nim_api_key_here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_RESCUE_MODEL=z-ai/glm4.7

# ===== Rescue chain priority #2: Gemini 3.1 flash lite =====
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ===== Rescue chain priority #3: Gemma 4 (MIMO/OpenAI-compatible endpoint) =====
# Keep this as gemma-4 unless you intentionally switch fallback model.
RESCUE_MODEL=gemma-4-31b-it

# ===== Legacy/compat switches (kept for backward compatibility) =====
# Current rescue code uses fixed chain above. This key is still read by config.

# ===== Runtime / workspace =====
WORKSPACE_DIR=workspace
TODO_FILE=todo.txt

# ===== Agent control =====
MAX_STEPS=50
MAX_HISTORY=10
MAX_CONTEXT_CHARS=60000
POLL_INTERVAL=2

# ===== Skill loading limits =====
MAX_SKILLS_LOADED=6
SKILL_SUMMARY_MAX_CHARS=600

# ===== MCP registry (optional) =====
# Comma-separated subset of supported MCP names:
# chrome-devtools, github, web-visual-feedback, context7, codegeneratormcp, semgrep
MCP_SERVERS=chrome-devtools,github,web-visual-feedback,context7,codegeneratormcp,semgrep
